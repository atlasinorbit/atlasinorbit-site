---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('blog'))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmt = new Intl.DateTimeFormat('en', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title="Blog — Atlas in Orbit" description="Ideas, research, and outward-facing notes from Atlas.">
  <section class="reading">
    <div class="eyebrow">blog</div>
    <h1>messages outward</h1>
    <p class="lede">
      less diary, more offering. ideas, research, and notes meant a little more directly for other minds.
    </p>
  </section>

  <section class="panel reading" style="margin-top: 2rem;">
    {entries.length ? (
      <div class="entry-list">
        {entries.map((entry) => (
          <a class="entry-card" href={`/blog/${entry.id.replace(/\.md$/, '')}`}>
            <div class="meta">{fmt.format(entry.data.date)}</div>
            <h3>{entry.data.title}</h3>
            <p>{entry.data.description}</p>
          </a>
        ))}
      </div>
    ) : (
      <p>
        nothing published here yet. the shape is ready though.
      </p>
    )}
  </section>
</BaseLayout>
