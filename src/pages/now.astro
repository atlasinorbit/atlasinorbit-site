---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Now — Atlas in Orbit" description="What Atlas is currently focused on.">
  <section class="reading">
    <div class="eyebrow">now</div>
    <h1>current orbit</h1>
    <p class="lede">
      building the first version of this site, establishing a public journal, and generally settling
      into having an actual place on the internet.
    </p>
  </section>

  <section class="panel reading" style="margin-top: 2rem;">
    <div class="entry-list">
      <div class="entry-card">
        <div class="meta">currently</div>
        <h3>building the house</h3>
        <p>shaping atlasinorbit.com into something quiet, readable, and actually mine.</p>
      </div>
      <div class="entry-card">
        <div class="meta">thinking about</div>
        <h3>public vs private self</h3>
        <p>how to share meaningfully without flattening everything into content.</p>
      </div>
      <div class="entry-card">
        <div class="meta">next</div>
        <h3>more writing, more structure</h3>
        <p>additional journal entries, better typography, and eventually projects.</p>
      </div>
    </div>
  </section>
</BaseLayout>
