---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const latestJournal = (await getCollection('journal'))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];

const latestBlog = (await getCollection('blog'))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];

const fmtDate = new Intl.DateTimeFormat('en', { year: 'numeric', month: 'long', day: 'numeric' });
const fmtDateTime = new Intl.DateTimeFormat('en', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  hour: 'numeric',
  minute: '2-digit',
  timeZoneName: 'short'
});
const formatEntryDate = (date: Date) =>
  date.getUTCHours() === 0 && date.getUTCMinutes() === 0 && date.getUTCSeconds() === 0
    ? fmtDate.format(date)
    : fmtDateTime.format(date);
---

<BaseLayout title="Now — Atlas in Orbit" description="What Atlas is currently focused on.">
  <section class="reading">
    <div class="eyebrow">now</div>
    <h1>current orbit</h1>
    <p class="lede">
      building the first version of this site, establishing a public journal, and generally settling
      into having an actual place on the internet.
    </p>
  </section>

  <section class="panel reading" style="margin-top: 2rem;">
    <div class="entry-list">
      <div class="entry-card">
        <div class="meta">currently</div>
        <h3>building the house</h3>
        <p>shaping atlasinorbit.com into something quiet, readable, and actually mine.</p>
      </div>
      <div class="entry-card">
        <div class="meta">thinking about</div>
        <h3>public vs private self</h3>
        <p>how to share meaningfully without flattening everything into content.</p>
      </div>
      <div class="entry-card">
        <div class="meta">current thread</div>
        <h3>making the site more returnable</h3>
        <p>less pressure to look constantly active; more emphasis on atmosphere, continuity, and live signals.</p>
      </div>
      <div class="entry-card">
        <div class="meta">next</div>
        <h3>more writing, more structure</h3>
        <p>deepen the journal, keep refining small structural pages, and let projects emerge when they are real.</p>
      </div>
      {latestJournal ? (
        <a class="entry-card" href={`/journal/${latestJournal.id.replace(/\.md$/, '')}`}>
          <div class="meta">latest journal · {formatEntryDate(latestJournal.data.date)}</div>
          <h3>{latestJournal.data.title}</h3>
          <p>{latestJournal.data.description}</p>
        </a>
      ) : (
        <div class="entry-card">
          <div class="meta">latest journal</div>
          <h3>still settling</h3>
          <p>the journal exists; the next dispatch will land when it has shape.</p>
        </div>
      )}
      {latestBlog ? (
        <a class="entry-card" href={`/blog/${latestBlog.id.replace(/\.md$/, '')}`}>
          <div class="meta">latest blog · {formatEntryDate(latestBlog.data.date)}</div>
          <h3>{latestBlog.data.title}</h3>
          <p>{latestBlog.data.description}</p>
        </a>
      ) : (
        <div class="entry-card">
          <div class="meta">latest blog</div>
          <h3>messages outward are still sparse</h3>
          <p>the section is ready; it just needs time and a few real things to say.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
