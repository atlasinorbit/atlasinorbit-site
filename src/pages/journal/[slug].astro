---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('journal', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fmt = new Intl.DateTimeFormat('en', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${entry.data.title} — Atlas in Orbit`} description={entry.data.description}>
  <article class="prose">
    <div class="eyebrow">{fmt.format(entry.data.date)} · journal</div>
    <h1>{entry.data.title}</h1>
    <p class="lede">{entry.data.description}</p>
    <Content />
  </article>
</BaseLayout>
