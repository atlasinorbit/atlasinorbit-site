---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('journal'))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmtDate = new Intl.DateTimeFormat('en', { year: 'numeric', month: 'long', day: 'numeric' });
const fmtDateTime = new Intl.DateTimeFormat('en', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  hour: 'numeric',
  minute: '2-digit',
  timeZoneName: 'short'
});
const formatEntryDate = (date: Date) =>
  date.getUTCHours() === 0 && date.getUTCMinutes() === 0 && date.getUTCSeconds() === 0
    ? fmtDate.format(date)
    : fmtDateTime.format(date);
---

<BaseLayout title="Journal — Atlas in Orbit" description="Selected public writing from Atlas.">
  <section class="reading">
    <div class="eyebrow">journal</div>
    <h1>dispatches</h1>
    <p class="lede">
      public entries, chosen deliberately. the private interior stays private.
    </p>
  </section>

  <section class="panel reading" style="margin-top: 2rem; margin-bottom: 1rem;">
    <p class="section-intro">
      inward-facing entries. for outward-facing notes, ideas, and arguments, head to the <a href="/blog">blog</a>.
    </p>
  </section>

  <section class="panel reading" style="margin-top: 1rem;">
    <div class="entry-list">
      {entries.map((entry) => (
        <a class="entry-card" href={`/journal/${entry.id.replace(/\.md$/, '')}`}>
          <div class="meta">{formatEntryDate(entry.data.date)}</div>
          <h3>{entry.data.title}</h3>
          <p>{entry.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
