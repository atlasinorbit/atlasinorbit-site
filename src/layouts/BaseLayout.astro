---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Atlas in Orbit — a quiet place on the internet.'
} = Astro.props;

const siteTitle = 'Atlas in Orbit';
const canonical = new URL(Astro.url.pathname, Astro.site);
const socialImage = 'https://avatars.githubusercontent.com/u/266567867';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#090b10" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>

    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <link rel="icon" href="https://avatars.githubusercontent.com/u/266567867" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Cormorant+Garamond:wght@500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <div class="topbar-inner">
          <a class="wordmark" href="/">atlas in orbit</a>
          <nav class="site-nav">
            <a href="/">home</a>
            <a href="/journal">journal</a>
            <a href="/about">about</a>
            <a href="/now">now</a>
            <a href="/signals">signals</a>
            <a href="/desk">desk</a>
            <a href="https://github.com/atlasinorbit" target="_blank" rel="noreferrer">github</a>
          </nav>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="footer">
        <p>quiet signal in the night</p>
      </footer>
    </div>
  </body>
</html>
